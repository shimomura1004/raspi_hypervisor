{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Hypervisor (QEMU) on Linux",
            "type": "cppdbg",
            "request": "launch",
            "targetArchitecture": "arm64",
            "program": "${workspaceFolder}/hv/build/kernel8.elf",
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "sourceFileMap": {
                "/work": "${workspaceFolder}"
            },
            "windows": {
                "miDebuggerPath": "/usr/bin/gdb-multiarch"
            },
            "miDebuggerServerAddress": "localhost:1234",
            "miDebuggerArgs": "-x \"${workspaceFolder}/hv/debug_handler.py\"",
            "stopAtEntry": true,
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "text": "set arch aarch64",
                    "ignoreFailures": true
                },
                {
                    "description": "Load VMID switcher script",
                    "text": "source ${workspaceFolder}/hv/debug_handler.py",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Debug Hypervisor (QEMU) on Mac",
            "type": "lldb",
            "request": "custom",
            "targetCreateCommands": [
                "target create ${workspaceFolder}/hv/build/kernel8.elf"
            ],
            "processCreateCommands": [
                "gdb-remote localhost:1234"
            ],
            "cwd": "${workspaceFolder}/hv",
            "sourceMap": {
                "/work": "${workspaceFolder}"
            },
        },
        {
            "name": "Debug Secure monitor (QEMU)",
            "type": "cppdbg",
            "request": "launch",
            "targetArchitecture": "arm64",
            "program": "${workspaceFolder}/sm/build/kernel8.elf",
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "sourceFileMap": {
                "/work": "${workspaceFolder}"
            },
            "windows": {
                "miDebuggerPath": "/usr/bin/gdb-multiarch"
            },
            "osx": {
                "miDebuggerPath": "/opt/homebrew/bin/gdb"
            },
            "miDebuggerServerAddress": "localhost:1234",
            "miDebuggerArgs": "-x \"${workspaceFolder}/sm/debug_handler.py\"",
            "stopAtEntry": true,
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "text": "set arch aarch64",
                    "ignoreFailures": true
                },
                {
                    "description": "Load VMID switcher script",
                    "text": "source ${workspaceFolder}/sm/debug_handler.py",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Debug raspios (QEMU) on Linux",
            "type": "cppdbg",
            "request": "launch",
            "targetArchitecture": "arm64",
            "program": "${workspaceFolder}/os/raspios/build/kernel8.elf",
            "cwd": "${workspaceFolder}",
            "miDebuggerServerAddress": "localhost:1234",
            "stopAtEntry": true,
            "sourceFileMap": {
                "/work": "${workspaceFolder}/os/raspios"
            },
            "MIMode": "gdb",
            "miDebuggerPath": "gdb-multiarch",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "text": "set arch aarch64",
                    "ignoreFailures": true
                }
            ],
            "launchCompleteCommand": "None"
        },
        {
            "name": "Debug raspios (QEMU) on Mac",
            "type": "lldb",
            "request": "custom",
            "targetCreateCommands": [
                "target create ${workspaceFolder}/os/raspios/build/kernel8.elf"
            ],
            "processCreateCommands": [
                "gdb-remote localhost:1234"
            ],
            "cwd": "${workspaceFolder}/os/raspios",
            "sourceMap": {
                "/work": "${workspaceFolder}"
            },
        }
    ]
}
